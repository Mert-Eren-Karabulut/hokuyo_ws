<?xml version="1.0"?>
<!--
    Acquire data only (no solving).
    
    mode:  "pan"  → sweep pan with tilt=0 (for Stage 1)
           "tilt" → sweep tilt with pan=0 (for Stage 2)
           "both" → full grid (for validation)

    Usage:
      roslaunch ptu_calib_cpp acquire.launch mode:=pan
      roslaunch ptu_calib_cpp acquire.launch mode:=tilt
      roslaunch ptu_calib_cpp acquire.launch mode:=both
-->
<launch>
    <arg name="mode"            default="pan" />
    <arg name="pan_lower_deg"  default="-15.0" />
    <arg name="pan_upper_deg"  default="15.0" />
    <arg name="tilt_lower_deg" default="-5.0" />
    <arg name="tilt_upper_deg" default="20.0" />
    <arg name="pan_steps"       default="20" />
    <arg name="tilt_steps"      default="20" />
    <arg name="fov_half_deg"    default="15.0" />
    <arg name="settle_time"     default="1.0" />
    <arg name="output_dir"      default="$(find ptu_calib_cpp)/results" />

    <node pkg="ptu_calib_cpp" type="acquire_node"
          name="ptu_calib_acquire" output="screen">
        <param name="mode"            value="$(arg mode)" />
        <param name="pan_lower_deg"   value="$(arg pan_lower_deg)" />
        <param name="pan_upper_deg"   value="$(arg pan_upper_deg)" />
        <param name="tilt_lower_deg"  value="$(arg tilt_lower_deg)" />
        <param name="tilt_upper_deg"  value="$(arg tilt_upper_deg)" />
        <param name="pan_steps"       value="$(arg pan_steps)" />
        <param name="tilt_steps"      value="$(arg tilt_steps)" />
        <param name="fov_half_deg"    value="$(arg fov_half_deg)" />
        <param name="settle_time"     value="$(arg settle_time)" />
        <param name="output_dir"      value="$(arg output_dir)" />
    </node>
</launch>
